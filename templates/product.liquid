{% comment %}
  Product Page - 白底柠檬黄绿风格
{% endcomment %}

<style>
  :root {
    --white: #FFFFFF;
    --black: #1A1A1A;
    --gray: #666666;
    --gray-light: #F5F5F5;
    --lime: #F0FF0A;
    --pink: #FF007D;
  }

  .product-page {
    padding-top: 100px;
    min-height: 100vh;
    background: var(--white);
  }

  .product-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 60px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
  }

  /* Gallery */
  .product-gallery {
    position: sticky;
    top: 120px;
    height: fit-content;
  }

  .main-image {
    aspect-ratio: 1;
    background: var(--gray-light);
    border-radius: 30px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
  }

  .main-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .thumbnail-list {
    display: flex;
    gap: 15px;
    overflow-x: auto;
  }

  .thumbnail {
    width: 80px;
    height: 80px;
    background: var(--gray-light);
    border-radius: 12px;
    overflow: hidden;
    cursor: pointer;
    border: 2px solid transparent;
    transition: all 0.3s;
  }

  .thumbnail:hover,
  .thumbnail.active {
    border-color: var(--lime);
  }

  .thumbnail img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Product Info */
  .product-info {
    padding-top: 20px;
  }

  .product-breadcrumbs {
    font-size: 13px;
    color: var(--gray);
    margin-bottom: 20px;
    font-family: 'Noto Sans SC', sans-serif;
  }

  .product-breadcrumbs a {
    color: var(--gray);
    text-decoration: none;
    transition: color 0.3s;
  }

  .product-breadcrumbs a:hover {
    color: var(--pink);
  }

  .product-type {
    display: inline-block;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--pink);
    margin-bottom: 15px;
    font-family: 'Montserrat', sans-serif;
  }

  .product-title {
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 800;
    margin-bottom: 20px;
    color: var(--black);
    font-family: 'Noto Sans SC', sans-serif;
    line-height: 1.2;
  }

  .product-rating {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 25px;
  }

  .stars {
    font-size: 18px;
  }

  .rating-text {
    font-size: 14px;
    color: var(--gray);
    font-family: 'Noto Sans SC', sans-serif;
  }

  .product-price-box {
    display: flex;
    align-items: baseline;
    gap: 15px;
    margin-bottom: 30px;
    padding-bottom: 30px;
    border-bottom: 1px solid var(--gray-light);
  }

  .product-price {
    font-size: 42px;
    font-weight: 800;
    color: var(--black);
    font-family: 'Montserrat', sans-serif;
  }

  .product-compare-price {
    font-size: 24px;
    color: var(--gray);
    text-decoration: line-through;
    font-family: 'Montserrat', sans-serif;
  }

  .product-badge-sale {
    background: var(--pink);
    color: var(--white);
    padding: 6px 14px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 700;
    font-family: 'Montserrat', sans-serif;
  }

  .product-description {
    font-size: 16px;
    color: var(--gray);
    line-height: 1.8;
    margin-bottom: 30px;
    font-family: 'Noto Sans SC', sans-serif;
  }

  /* Variants */
  .variant-section {
    margin-bottom: 25px;
  }

  .variant-label {
    font-size: 14px;
    font-weight: 600;
    color: var(--black);
    margin-bottom: 12px;
    font-family: 'Noto Sans SC', sans-serif;
  }

  .variant-options {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .variant-option {
    padding: 12px 24px;
    border: 2px solid var(--black);
    border-radius: 30px;
    font-size: 14px;
    font-weight: 600;
    font-family: 'Noto Sans SC', sans-serif;
    cursor: pointer;
    transition: all 0.3s;
    background: var(--white);
  }

  .variant-option:hover,
  .variant-option.selected {
    background: var(--lime);
  }

  /* Quantity */
  .quantity-section {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 30px;
  }

  .quantity-selector {
    display: flex;
    align-items: center;
    border: 2px solid var(--black);
    border-radius: 30px;
    overflow: hidden;
  }

  .qty-btn {
    width: 50px;
    height: 50px;
    background: var(--white);
    border: none;
    font-size: 20px;
    cursor: pointer;
    transition: all 0.3s;
  }

  .qty-btn:hover {
    background: var(--gray-light);
  }

  .qty-input {
    width: 60px;
    height: 50px;
    border: none;
    text-align: center;
    font-size: 18px;
    font-weight: 700;
    font-family: 'Montserrat', sans-serif;
  }

  /* Add to Cart */
  .add-to-cart-btn {
    flex: 1;
    padding: 18px 40px;
    background: var(--pink);
    color: var(--white);
    border: none;
    border-radius: 30px;
    font-size: 16px;
    font-weight: 800;
    letter-spacing: 1px;
    font-family: 'Noto Sans SC', sans-serif;
    cursor: pointer;
    transition: all 0.3s;
  }

  .add-to-cart-btn:hover {
    transform: scale(1.02);
    box-shadow: 0 10px 30px rgba(255,0,125,0.3);
  }

  /* Features */
  .product-features {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    padding: 30px;
    background: var(--gray-light);
    border-radius: 20px;
    margin-top: 30px;
  }

  .feature-item {
    text-align: center;
  }

  .feature-icon {
    font-size: 30px;
    margin-bottom: 8px;
  }

  .feature-text {
    font-size: 13px;
    font-weight: 600;
    color: var(--black);
    font-family: 'Noto Sans SC', sans-serif;
  }

  /* Responsive */
  @media (max-width: 968px) {
    .product-container {
      grid-template-columns: 1fr;
      padding: 40px 20px;
    }

    .product-gallery {
      position: static;
    }

    .product-features {
      grid-template-columns: 1fr;
    }

    .quantity-section {
      flex-direction: column;
      align-items: stretch;
    }

    .add-to-cart-btn {
      width: 100%;
    }
  }
</style>

<div class="product-page">
  <div class="product-container">
    <!-- Gallery -->
    <div class="product-gallery">
      <div class="main-image">
        {%- if product.featured_image -%}
          <img src="{{ product.featured_image | img_url: 'large' }}" alt="{{ product.title }}" id="mainImage">
        {%- else -%}
          <span style="font-size: 100px;">🌟</span>
        {%- endif -%}
      </div>

      {%- if product.images.size > 1 -%}
        <div class="thumbnail-list">
          {%- for image in product.images limit: 4 -%}
            <div class="thumbnail {% if forloop.first %}active{% endif %}" onclick="changeImage('{{ image | img_url: 'large' }}', this)">
              <img src="{{ image | img_url: 'small' }}" alt="{{ product.title }}">
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <!-- Product Info -->
    <div class="product-info">
      <div class="product-breadcrumbs">
        <a href="/">首页</a> / <a href="/collections/all">商店</a> / <span>{{ product.title }}</span>
      </div>

      <span class="product-type">{{ product.type | default: "ART" }}</span>
      <h1 class="product-title">{{ product.title }}</h1>

      <div class="product-rating">
        <span class="stars">⭐⭐⭐⭐⭐</span>
        <span class="rating-text">{{ product.metafields.reviews.rating | default: "4.9" }} · {{ product.metafields.reviews.count | default: "128" }} 条评价</span>
      </div>

      <div class="product-price-box">
        <span class="product-price">{{ product.price | money }}</span>
        {%- if product.compare_at_price > product.price -%}
          <span class="product-compare-price">{{ product.compare_at_price | money }}</span>
          <span class="product-badge-sale">立省 {{ product.compare_at_price | minus: product.price | money }}</span>
        {%- endif -%}
      </div>

      <div class="product-description">
        {{ product.description | strip_html | truncate: 200 }}
      </div>

      <form method="post" action="/cart/add" id="product-form">
        {%- unless product.has_only_default_variant -%}
          {%- for option in product.options_with_values -%}
            <div class="variant-section">
              <div class="variant-label">{{ option.name }}</div>
              <div class="variant-options">
                {%- for value in option.values -%}
                  <button type="button" class="variant-option {% if forloop.first %}selected{% endif %}" data-option="{{ option.name }}" data-value="{{ value }}">{{ value }}</button>
                {%- endfor -%}
              </div>
            </div>
          {%- endfor -%}
        {%- endunless -%}

        <select name="id" id="product-select" style="display: none;">
          {%- for variant in product.variants -%}
            <option value="{{ variant.id }}" {% if variant == product.selected_or_first_available_variant %}selected{% endif %} data-available="{{ variant.available }}" data-price="{{ variant.price }}">{{ variant.title }}</option>
          {%- endfor -%}
        </select>

        <div class="quantity-section">
          <div class="quantity-selector">
            <button type="button" class="qty-btn" onclick="changeQty(-1)">-</button>
            <input type="number" name="quantity" value="1" min="1" class="qty-input" id="qtyInput">
            <button type="button" class="qty-btn" onclick="changeQty(1)">+</button>
          </div>

          <button type="submit" class="add-to-cart-btn">加入购物车 🛒</button>
        </div>
      </form>

      <div class="product-features">
        <div class="feature-item">
          <div class="feature-icon">🚚</div>
          <div class="feature-text">全球包邮</div>
        </div>
        <div class="feature-item">
          <div class="feature-icon">✨</div>
          <div class="feature-text">手工制作</div>
        </div>
        <div class="feature-item">
          <div class="feature-icon">🎁</div>
          <div class="feature-text">精美包装</div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  function changeImage(src, thumb) {
    document.getElementById('mainImage').src = src;
    document.querySelectorAll('.thumbnail').forEach(t => t.classList.remove('active'));
    thumb.classList.add('active');
  }

  function changeQty(delta) {
    const input = document.getElementById('qtyInput');
    const newVal = parseInt(input.value) + delta;
    if (newVal >= 1) {
      input.value = newVal;
    }
  }

  // Variant selection
  document.querySelectorAll('.variant-option').forEach(btn => {
    btn.addEventListener('click', function() {
      const optionName = this.dataset.option;
      document.querySelectorAll(`.variant-option[data-option="${optionName}"]`).forEach(b => b.classList.remove('selected'));
      this.classList.add('selected');
      updateVariant();
    });
  });

  function updateVariant() {
    const selectedOptions = [];
    document.querySelectorAll('.variant-option.selected').forEach(btn => {
      selectedOptions.push(btn.dataset.value);
    });

    const select = document.getElementById('product-select');
    for (let i = 0; i < select.options.length; i++) {
      const option = select.options[i];
      if (option.text.trim() === selectedOptions.join(' / ')) {
        select.selectedIndex = i;
        break;
      }
    }
  }
</script>