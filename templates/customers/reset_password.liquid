{% layout 'theme' %}

<style>
@import url('https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap');

.reset-page {
  min-height: 100vh;
  background: linear-gradient(135deg, #0a0a0f 0%, #1a1a2e 50%, #252542 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 120px 20px 40px;
}

.game-console {
  background: #2d2d44;
  border: 6px solid #000;
  border-radius: 30px;
  padding: 50px 40px;
  max-width: 480px;
  width: 100%;
  box-shadow: 
    0 0 0 4px #9D4EDD,
    0 20px 60px rgba(0,0,0,0.5);
  text-align: center;
}

.reset-icon {
  font-size: 70px;
  margin-bottom: 20px;
  animation: shake 2s infinite;
}

@keyframes shake {
  0%, 100% { transform: rotate(0deg); }
  25% { transform: rotate(-10deg); }
  75% { transform: rotate(10deg); }
}

.reset-title {
  font-family: 'Press Start 2P', monospace;
  font-size: 18px;
  color: #9D4EDD;
  margin-bottom: 20px;
  text-shadow: 3px 3px 0 #000;
}

.reset-text {
  font-family: 'Press Start 2P', monospace;
  font-size: 10px;
  color: rgba(255,255,255,0.7);
  line-height: 2;
  margin-bottom: 30px;
}

.pixel-form {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.form-label {
  font-family: 'Press Start 2P', monospace;
  font-size: 9px;
  color: #00D9FF;
  text-align: left;
  display: block;
  margin-bottom: 10px;
}

.form-input {
  width: 100%;
  padding: 18px 20px;
  background: #1a1a2e;
  border: 4px solid #000;
  border-radius: 12px;
  font-family: 'Press Start 2P', monospace;
  font-size: 11px;
  color: #FFE600;
  box-shadow: inset 0 4px 0 rgba(0,0,0,0.3);
}

.form-input:focus {
  outline: none;
  border-color: #9D4EDD;
}

.reset-btn {
  width: 100%;
  padding: 20px;
  background: #9D4EDD;
  border: 5px solid #000;
  border-radius: 16px;
  font-family: 'Press Start 2P', monospace;
  font-size: 12px;
  color: #fff;
  cursor: pointer;
  box-shadow: 0 8px 0 #000;
  margin-top: 10px;
}

.reset-btn:hover {
  transform: translateY(4px);
  box-shadow: 0 4px 0 #000;
}

.back-link {
  display: inline-block;
  margin-top: 30px;
  font-family: 'Press Start 2P', monospace;
  font-size: 10px;
  color: rgba(255,255,255,0.6);
  text-decoration: none;
}

.back-link:hover {
  color: #FFE600;
}
</style>

<div class="reset-page">
  <div class="game-console">
    <div class="reset-icon">🔑</div>
    <h1 class="reset-title">FORGOT CODE?</h1>
    <p class="reset-text">
      Enter your email and we'll send<br>
      you a reset link!
    </p>
    
    {% form 'recover_customer_password' %}
      <div class="pixel-form">
        <div>
          <label class="form-label">📧 EMAIL ADDRESS</label>
          <input 
            type="email" 
            name="email" 
            class="form-input" 
            placeholder="player@example.com"
            required
          >
        </div>
        
        <button type="submit" class="reset-btn">
          SEND RESET LINK →
        </button>
      </div>
    {% endform %}
    
    <a href="/account/login" class="back-link">← BACK TO LOGIN</a>
  </div>
</div>
