  <!-- ==================== 第9屏：紧迫感区 ==================== -->
  <section class="pd-urgency">
    <div class="urgency-box">
      <h2>⏰ LIMITED DROP</h2>
      
      <div class="urgency-stats">
        <div class="stat-item">
          <span class="stat-number" id="stockCount">{{ placeholder_stock }}</span>
          <span class="stat-label">件库存</span>
        </div>
        <div class="stat-item">
          <span class="stat-number" id="viewerCount">{{ placeholder_viewers }}</span>
          <span class="stat-label">人正在浏览</span>
        </div>
      </div>
      
      <p class="urgency-note">
