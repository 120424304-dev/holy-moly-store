  <!-- ==================== 第10屏：FAQ区 ==================== -->
  <section class="pd-faq">
    <h2 class="section-title">❓ 常见问题</h2>
    
    <div class="faq-list">
      <div class="faq-item">
        <button class="faq-question" onclick="toggleFaq(this)">
