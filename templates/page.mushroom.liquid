{% comment %}
  Product Detail Page - Mushroom Keychain
  独立产品详情页模板
{% endcomment %}

{{ 'holy-home.css' | asset_url | stylesheet_tag }}

<div id="holy-product">
  <!-- Navigation -->
  <nav class="top-nav" id="topNav">
    <a href="/" class="nav-logo">HOLY MOLY</a>
    <div class="nav-menu" id="navMenu">
      <a href="/collections/all" class="nav-link">SHOP</a>
      <a href="/pages/custom" class="nav-link">CUSTOM</a>
      <a href="/blogs/news" class="nav-link">BLOG</a>
      <a href="/pages/about" class="nav-link">ABOUT</a>
    </div>
    <button class="nav-cart-btn" onclick="window.location.href='/cart'">
      🛒
      <span class="nav-cart-count" id="cartCount">0</span>
    </button>
  </nav>

  <!-- Product Detail -->
  <section class="product-detail">
    <div class="product-container">
      <!-- Product Images -->
      <div class="product-gallery">
        <div class="main-image" style="--bg:linear-gradient(135deg,#FFE600,#FFB800)">
          <span class="emoji-large">🍄</span>
          <span class="product-tag tag-hot">HOT</span>
        </div>
        <div class="thumbnail-list">
          <div class="thumb active" style="--bg:linear-gradient(135deg,#FFE600,#FFB800)">🍄</div>
          <div class="thumb" style="--bg:#f0f0f0">📸</div>
          <div class="thumb" style="--bg:#f0f0f0">✨</div>
          <div class="thumb" style="--bg:#f0f0f0">🎁</div>
        </div>
      </div>

      <!-- Product Info -->
      <div class="product-info-panel">
        <div class="breadcrumb">
          <a href="/">Home</a> / <a href="/collections/all">Shop</a> / <span>Keychains</span>
        </div>
        
        <h1 class="product-name">Super Mushroom Keychain</h1>
        
        <div class="product-rating">
          <span class="stars">⭐⭐⭐⭐⭐</span>
          <span class="reviews">4.9 (127 reviews)</span>
        </div>
        
        <div class="product-price-large">
          <span class="current-price">$18.00</span>
          <span class="compare-price">$25.00</span>
          <span class="discount-badge">-28%</span>
        </div>
        
        <p class="product-description">
          经典8-bit像素风格马里奥蘑菇钥匙扣！每个都是手工拼豆制作，独一无二。
          高辨识度红帽子设计，玩家情怀满分。限量手工制作，不容错过！
        </p>
        
        <div class="product-features">
          <div class="feature-item">
            <span class="icon">✋</span>
            <span>手工制作</span>
          </div>
          <div class="feature-item">
            <span class="icon">📏</span>
            <span>5cm × 5cm</span>
          </div>
          <div class="feature-item">
            <span class="icon">⚖️</span>
            <span>30g</span>
          </div>
          <div class="feature-item">
            <span class="icon">📦</span>
            <span>全球包邮</span>
          </div>
        </div>
        
        <div class="quantity-selector">
          <span class="label">Quantity:</span>
          <div class="quantity-control">
            <button class="qty-btn" onclick="updateQty(-1)">-</button>
            <input type="number" id="quantity" value="1" min="1" max="10">
            <button class="qty-btn" onclick="updateQty(1)">+</button>
          </div>
        </div>
        
        <div class="action-buttons">
          <button class="btn-add-cart" onclick="addToCart()">
            <span class="icon">🛒</span>
            <span>ADD TO CART</span>
          </button>
          <button class="btn-buy-now" onclick="buyNow()">
            <span class="icon">⚡</span>
            <span>BUY NOW</span>
          </button>
        </div>
        
        <div class="trust-badges">
          <div class="badge">
            <span class="icon">🚚</span>
            <span>Free Shipping</span>
          </div>
          <div class="badge">
            <span class="icon">🔄</span>
            <span>30-Day Returns</span>
          </div>
          <div class="badge">
            <span class="icon">🔒</span>
            <span>Secure Checkout</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Product Details Tabs -->
  <section class="product-tabs">
    <div class="tabs-nav">
      <button class="tab-btn active" onclick="switchTab('description')">Description</button>
      <button class="tab-btn" onclick="switchTab('specs')">Specifications</button>
      <button class="tab-btn" onclick="switchTab('shipping')">Shipping</button>
      <button class="tab-btn" onclick="switchTab('reviews')">Reviews</button>
    </div>
    
    <div class="tab-content active" id="description">
      <h3>🍄 About This Product</h3>
      <p>Our Super Mushroom Keychain is a tribute to the golden age of gaming. Each piece is handcrafted with over 200 premium beads, carefully placed and iron-fused for durability.</p>
      <ul>
        <li>✨ 100% Handmade with love</li>
        <li>🎮 Perfect for gamers and collectors</li>
        <li>🎁 Great gift for Nintendo fans</li>
        <li>💪 Durable and long-lasting</li>
      </ul>
    </div>
    
    <div class="tab-content" id="specs">
      <h3>📐 Specifications</h3>
      <table class="specs-table">
        <tr><td>Material</td><td>Perler Beads (Food-grade plastic)</td></tr>
        <tr><td>Dimensions</td><td>5cm × 5cm × 0.5cm</td></tr>
        <tr><td>Weight</td><td>30g</td></tr>
        <tr><td>Attachment</td><td>Metal keyring included</td></tr>
        <tr><td>Care</td><td>Wipe clean with damp cloth</td></tr>
      </table>
    </div>
    
    <div class="tab-content" id="shipping">
      <h3>🚚 Shipping Information</h3>
      <p>We ship worldwide! Here are the estimated delivery times:</p>
      <ul>
        <li>🇺🇸 USA: 5-7 business days</li>
        <li>🇬🇧 UK: 7-10 business days</li>
        <li>🇪🇺 Europe: 7-12 business days</li>
        <li>🌏 Asia: 10-15 business days</li>
        <li>🌍 Rest of World: 12-20 business days</li>
      </ul>
      <p><strong>Free shipping on orders over $50!</strong></p>
    </div>
    
    <div class="tab-content" id="reviews">
      <h3>💬 Customer Reviews</h3>
      <div class="review-item">
        <div class="review-header">
          <span class="reviewer">Sarah M. ⭐⭐⭐⭐⭐</span>
          <span class="date">2 weeks ago</span>
        </div>
        <p>"Absolutely love this! Perfect addition to my keychain collection."</p>
      </div>
      <div class="review-item">
        <div class="review-header">
          <span class="reviewer">Mike T. ⭐⭐⭐⭐⭐</span>
          <span class="date">1 month ago</span>
        </div>
        <p>"Bought this for my gamer boyfriend and he loves it! Great quality."</p>
      </div>
    </div>
  </section>

  <!-- Related Products -->
  <section class="related-products">
    <h2 class="section-title">You May Also Like</h2>
    <div class="products-grid-small">
      <a href="/pages/products/pikachu-keychain" class="product-card-small">
        <div class="card-image" style="--bg:linear-gradient(135deg,#FF6B9D,#C44569)">⚡</div>
        <h4>Electric Sprite</h4>
        <span class="price">$28.00</span>
      </a>
      <a href="/pages/products/star-keychain" class="product-card-small">
        <div class="card-image" style="--bg:linear-gradient(135deg,#FFD93D,#FFA502)">⭐</div>
        <h4>Star Power</h4>
        <span class="price">$15.00</span>
      </a>
      <a href="/pages/products/ghost-keychain" class="product-card-small">
        <div class="card-image" style="--bg:linear-gradient(135deg,#FF2D7D,#C41E3A)">👻</div>
        <h4>Ghost Sprite</h4>
        <span class="price">$25.00</span>
      </a>
      <a href="/pages/products/diy-kit" class="product-card-small">
        <div class="card-image" style="--bg:linear-gradient(135deg,#9D4EDD,#7B2CBF)">🎁</div>
        <h4>DIY Kit</h4>
        <span class="price">$45.00</span>
      </a>
    </div>
  </section>

  <!-- Footer -->
  <footer class="holy-footer-v2">
    <div class="footer-grid-v2">
      <div class="footer-brand-v2">
        <h3>HOLY MOLY</h3>
        <p>Handmade pixel art for gamers and nostalgia lovers.</p>
      </div>
      <div class="footer-col-v2">
        <h4>SHOP</h4>
        <ul>
          <li><a href="/collections/all">All Products</a></li>
          <li><a href="/collections/keychains">Keychains</a></li>
          <li><a href="/pages/custom">Custom Orders</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom-v2">
      © 2024 HOLY MOLY BEADS 🎮
    </div>
  </footer>
</div>

<style>
#holy-product {
  font-family: 'Inter', sans-serif;
  background: #0a0a0f;
  color: white;
  min-height: 100vh;
  padding-top: 80px;
}

.product-detail {
  padding: 40px 5%;
  max-width: 1400px;
  margin: 0 auto;
}

.product-container {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: start;
}

.product-gallery {
  position: sticky;
  top: 100px;
}

.main-image {
  width: 100%;
  aspect-ratio: 1;
  background: var(--bg);
  border-radius: 28px;
  border: 5px solid #000;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  box-shadow: 12px 12px 0 rgba(0,0,0,0.3);
}

.emoji-large {
  font-size: 200px;
}

.thumbnail-list {
  display: flex;
  gap: 15px;
  margin-top: 20px;
}

.thumb {
  width: 80px;
  height: 80px;
  background: var(--bg);
  border-radius: 12px;
  border: 3px solid #333;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40px;
  cursor: pointer;
  transition: all 0.2s;
}

.thumb.active, .thumb:hover {
  border-color: var(--pixel-yellow);
}

.product-info-panel {
  padding: 20px 0;
}

.breadcrumb {
  font-size: 14px;
  color: #888;
  margin-bottom: 20px;
}

.breadcrumb a {
  color: var(--pixel-cyan);
  text-decoration: none;
}

.product-name {
  font-family: 'Press Start 2P', cursive;
  font-size: 28px;
  line-height: 1.5;
  margin-bottom: 15px;
}

.product-rating {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 20px;
}

.stars {
  font-size: 20px;
}

.reviews {
  color: #888;
}

.product-price-large {
  display: flex;
  align-items: center;
  gap: 15px;
  margin-bottom: 25px;
}

.current-price {
  font-size: 48px;
  font-weight: 800;
  color: var(--pixel-pink);
}

.compare-price {
  font-size: 24px;
  color: #666;
  text-decoration: line-through;
}

.discount-badge {
  background: var(--pixel-pink);
  color: white;
  padding: 5px 12px;
  border-radius: 20px;
  font-size: 14px;
  font-weight: 700;
}

.product-description {
  font-size: 16px;
  line-height: 1.8;
  color: #ccc;
  margin-bottom: 30px;
}

.product-features {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 15px;
  margin-bottom: 30px;
}

.feature-item {
  display: flex;
  align-items: center;
  gap: 10px;
  background: rgba(255,255,255,0.05);
  padding: 12px 15px;
  border-radius: 12px;
}

.feature-item .icon {
  font-size: 20px;
}

.quantity-selector {
  display: flex;
  align-items: center;
  gap: 20px;
  margin-bottom: 25px;
}

.quantity-control {
  display: flex;
  align-items: center;
  border: 3px solid #333;
  border-radius: 12px;
  overflow: hidden;
}

.qty-btn {
  width: 45px;
  height: 45px;
  background: #333;
  border: none;
  color: white;
  font-size: 20px;
  cursor: pointer;
}

.quantity-control input {
  width: 60px;
  height: 45px;
  background: transparent;
  border: none;
  color: white;
  text-align: center;
  font-size: 18px;
}

.action-buttons {
  display: flex;
  gap: 15px;
  margin-bottom: 30px;
}

.btn-add-cart, .btn-buy-now {
  flex: 1;
  padding: 18px 30px;
  border: 4px solid #000;
  border-radius: 16px;
  font-family: 'Press Start 2P', cursive;
  font-size: 12px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  box-shadow: 5px 5px 0 #000;
  transition: all 0.2s;
}

.btn-add-cart {
  background: var(--pixel-yellow);
  color: #000;
}

.btn-buy-now {
  background: var(--pixel-pink);
  color: white;
}

.btn-add-cart:hover, .btn-buy-now:hover {
  transform: translate(2px, 2px);
  box-shadow: 3px 3px 0 #000;
}

.trust-badges {
  display: flex;
  gap: 20px;
  flex-wrap: wrap;
}

.badge {
  display: flex;
  align-items: center;
  gap: 8px;
  color: #888;
  font-size: 14px;
}

/* Tabs */
.product-tabs {
  max-width: 1400px;
  margin: 60px auto;
  padding: 0 5%;
}

.tabs-nav {
  display: flex;
  gap: 10px;
  border-bottom: 2px solid #333;
  margin-bottom: 30px;
}

.tab-btn {
  padding: 15px 25px;
  background: transparent;
  border: none;
  color: #888;
  font-family: 'Press Start 2P', cursive;
  font-size: 10px;
  cursor: pointer;
  position: relative;
}

.tab-btn.active {
  color: var(--pixel-yellow);
}

.tab-btn.active::after {
  content: '';
  position: absolute;
  bottom: -2px;
  left: 0;
  right: 0;
  height: 3px;
  background: var(--pixel-yellow);
}

.tab-content {
  display: none;
  animation: fadeIn 0.3s ease;
}

.tab-content.active {
  display: block;
}

.tab-content h3 {
  font-family: 'Press Start 2P', cursive;
  font-size: 16px;
  margin-bottom: 20px;
  color: var(--pixel-cyan);
}

.tab-content p, .tab-content ul {
  line-height: 1.8;
  color: #ccc;
  margin-bottom: 15px;
}

.tab-content ul {
  list-style: none;
}

.tab-content li {
  margin-bottom: 10px;
}

.specs-table {
  width: 100%;
  border-collapse: collapse;
}

.specs-table td {
  padding: 15px;
  border-bottom: 1px solid #333;
}

.specs-table td:first-child {
  color: #888;
  width: 30%;
}

.review-item {
  background: rgba(255,255,255,0.05);
  padding: 20px;
  border-radius: 12px;
  margin-bottom: 15px;
}

.review-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10px;
}

.reviewer {
  color: var(--pixel-cyan);
}

.date {
  color: #666;
  font-size: 14px;
}

/* Related Products */
.related-products {
  max-width: 1400px;
  margin: 80px auto;
  padding: 0 5%;
}

.related-products .section-title {
  font-family: 'Press Start 2P', cursive;
  font-size: 20px;
  text-align: center;
  margin-bottom: 40px;
}

.products-grid-small {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 25px;
}

.product-card-small {
  background: rgba(255,255,255,0.05);
  border-radius: 16px;
  overflow: hidden;
  text-decoration: none;
  color: white;
  transition: transform 0.3s;
}

.product-card-small:hover {
  transform: translateY(-10px);
}

.card-image {
  aspect-ratio: 1;
  background: var(--bg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60px;
}

.product-card-small h4 {
  padding: 15px;
  font-size: 14px;
}

.product-card-small .price {
  display: block;
  padding: 0 15px 15px;
  color: var(--pixel-pink);
  font-weight: 700;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

@media (max-width: 900px) {
  .product-container {
    grid-template-columns: 1fr;
  }
  .product-gallery {
    position: relative;
    top: 0;
  }
  .products-grid-small {
    grid-template-columns: repeat(2, 1fr);
  }
}
</style>

<script>
let qty = 1;

function updateQty(change) {
  qty = Math.max(1, Math.min(10, qty + change));
  document.getElementById('quantity').value = qty;
}

function addToCart() {
  // Add to cart logic here
  alert('Added to cart! (Demo)');
}

function buyNow() {
  // Buy now logic here
  alert('Redirecting to checkout... (Demo)');
}

function switchTab(tabId) {
  document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
  document.querySelectorAll('.tab-content').forEach(content => content.classList.remove('active'));
  
  event.target.classList.add('active');
  document.getElementById(tabId).classList.add('active');
}
</script>