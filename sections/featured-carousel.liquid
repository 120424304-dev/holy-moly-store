<style>
@import url('https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap');

.featured-shop-section { 
    background: linear-gradient(180deg, #0a0a0f 0%, #1a1a2e 100%); 
    padding: 100px 20px; 
    position: relative;
    overflow: hidden;
}

/* 装饰背景 */
.featured-shop-section::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background-image: 
        radial-gradient(circle at 20% 80%, rgba(255, 230, 0, 0.1) 0%, transparent 50%),
        radial-gradient(circle at 80% 20%, rgba(255, 45, 125, 0.1) 0%, transparent 50%);
    pointer-events: none;
}

.featured-header { 
    text-align: center; 
    margin-bottom: 50px;
    position: relative;
    z-index: 1;
}

.featured-title { 
    font-family: 'Press Start 2P', cursive; 
    font-size: clamp(20px, 4vw, 32px); 
    color: #FFE600; 
    margin-bottom: 16px;
    text-shadow: 3px 3px 0 #FF2D7D, 6px 6px 0 #00D9FF;
    animation: titleGlow 3s ease-in-out infinite;
}

@keyframes titleGlow {
    0%, 100% { text-shadow: 3px 3px 0 #FF2D7D, 6px 6px 0 #00D9FF; }
    50% { text-shadow: 3px 3px 0 #00D9FF, 6px 6px 0 #FF2D7D; }
}

.featured-subtitle { 
    font-family: 'Press Start 2P', cursive; 
    font-size: 11px; 
    color: rgba(255,255,255,0.5); 
}

/* 滑动容器 */
.carousel-container {
    position: relative;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 60px;
}

.carousel-wrapper {
    overflow: hidden;
    position: relative;
}

.carousel-track {
    display: flex;
    gap: 24px;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

/* 产品卡片 - 滑动专用 */
.carousel-card {
    flex: 0 0 calc(25% - 18px);
    min-width: 260px;
    background: #1a1a2e;
    border: 4px solid rgba(255,255,255,0.1);
    border-radius: 20px;
    overflow: hidden;
    position: relative;
    transition: all 0.3s;
    cursor: pointer;
}

.carousel-card:hover {
    border-color: #FFE600;
    transform: translateY(-10px);
    box-shadow: 0 20px 40px rgba(255, 230, 0, 0.2);
}

.carousel-card-inner { position: relative; }

/* 顶部标签 */
.carousel-badge {
    position: absolute;
    top: 16px; left: 16px;
    font-family: 'Press Start 2P';
    font-size: 9px;
    padding: 8px 14px;
    background: #FF2D7D;
    border: 3px solid #000;
    border-radius: 6px;
    color: white;
    box-shadow: 3px 3px 0 rgba(0,0,0,0.3);
    z-index: 5;
    animation: badgePulse 2s infinite;
}

@keyframes badgePulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.05); }
}

/* 图片区 */
.carousel-image-wrapper {
    height: 200px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
}

.carousel-image-wrapper::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 50%;
    background: linear-gradient(transparent, rgba(0,0,0,0.3));
}

.carousel-emoji {
    font-size: 80px;
    animation: floatEmoji 3s ease-in-out infinite;
    filter: drop-shadow(0 10px 20px rgba(0,0,0,0.3));
}

@keyframes floatEmoji {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-15px) rotate(5deg); }
}

.carousel-card:hover .carousel-emoji {
    animation: shake 0.5s ease;
}

@keyframes shake {
    0%, 100% { transform: rotate(0deg); }
    25% { transform: rotate(-10deg); }
    75% { transform: rotate(10deg); }
}

/* 信息区 */
.carousel-info {
    padding: 20px;
    background: white;
}

.carousel-meta {
    display: flex;
    justify-content: space-between;
    margin-bottom: 10px;
    align-items: center;
}

.carousel-type {
    font-family: 'Press Start 2P';
    font-size: 8px;
    color: #9D4EDD;
    background: rgba(157,78,221,0.1);
    padding: 4px 8px;
    border-radius: 4px;
}

.carousel-price {
    font-family: 'Press Start 2P';
    font-size: 14px;
    color: #FF2D7D;
}

.carousel-title {
    font-family: 'Press Start 2P';
    font-size: 10px;
    color: #000;
    line-height: 1.6;
    margin-bottom: 16px;
    min-height: 32px;
}

/* 快速添加按钮 */
.carousel-add-btn {
    width: 100%;
    padding: 14px;
    background: #FFE600;
    border: 4px solid #000;
    border-radius: 12px;
    font-family: 'Press Start 2P';
    font-size: 10px;
    color: #000;
    cursor: pointer;
    box-shadow: 4px 4px 0 #000;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
}

.carousel-add-btn:hover {
    transform: translate(2px, 2px);
    box-shadow: 2px 2px 0 #000;
    background: #00D9FF;
}

/* 导航箭头 */
.carousel-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 56px;
    height: 56px;
    background: #FFE600;
    border: 4px solid #000;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    box-shadow: 4px 4px 0 #000;
    transition: all 0.2s;
    z-index: 10;
}

.carousel-nav:hover {
    transform: translateY(-50%) scale(1.1);
    background: #FF2D7D;
}

.carousel-nav.prev { left: 0; }
.carousel-nav.next { right: 0; }

.carousel-nav:active {
    transform: translateY(-50%) scale(0.95);
    box-shadow: 2px 2px 0 #000;
}

/* 指示点 */
.carousel-dots {
    display: flex;
    justify-content: center;
    gap: 12px;
    margin-top: 40px;
}

.carousel-dot {
    width: 14px;
    height: 14px;
    background: rgba(255,255,255,0.2);
    border: 3px solid rgba(255,255,255,0.3);
    border-radius: 50%;
    cursor: pointer;
    transition: all 0.3s;
}

.carousel-dot.active {
    background: #FFE600;
    border-color: #000;
    box-shadow: 0 0 15px #FFE600;
    transform: scale(1.3);
}

/* CTA 按钮 */
.go-to-shop-container {
    text-align: center;
    margin-top: 60px;
}

.go-to-shop-btn {
    display: inline-flex;
    align-items: center;
    gap: 16px;
    font-family: 'Press Start 2P';
    font-size: 14px;
    padding: 28px 48px;
    background: linear-gradient(135deg, #FFE600, #FFD000);
    border: 6px solid #000;
    border-radius: 20px;
    color: #000;
    text-decoration: none;
    box-shadow: 8px 8px 0 #000, 0 0 40px rgba(255, 230, 0, 0.3);
    transition: all 0.3s;
    position: relative;
    overflow: hidden;
}

.go-to-shop-btn::before {
    content: '🎁';
    font-size: 24px;
}

.go-to-shop-btn::after {
    content: '→';
    font-size: 20px;
    transition: transform 0.3s;
}

.go-to-shop-btn:hover {
    transform: translate(4px, 4px);
    box-shadow: 4px 4px 0 #000;
    background: linear-gradient(135deg, #FF2D7D, #FF6B9D);
    color: white;
}

.go-to-shop-btn:hover::after {
    transform: translateX(8px);
}

/* 粒子装饰 */
.carousel-particles {
    position: absolute;
    width: 100%;
    height: 100%;
    pointer-events: none;
    overflow: hidden;
}

.particle {
    position: absolute;
    font-size: 20px;
    opacity: 0.3;
    animation: particleFloat 15s infinite;
}

@keyframes particleFloat {
    0%, 100% { transform: translateY(100vh) rotate(0deg); opacity: 0; }
    10% { opacity: 0.3; }
    90% { opacity: 0.3; }
    100% { transform: translateY(-100vh) rotate(720deg); opacity: 0; }
}

/* 响应式 */
@media (max-width: 1024px) {
    .carousel-card { flex: 0 0 calc(33.333% - 16px); }
}

@media (max-width: 768px) {
    .carousel-container { padding: 0 20px; }
    .carousel-card { flex: 0 0 calc(50% - 12px); min-width: 160px; }
    .carousel-nav { 
        width: 44px; 
        height: 44px; 
        font-size: 18px;
        position: relative;
        top: auto;
        transform: none;
        margin: 20px 10px 0;
    }
    .carousel-nav:hover { transform: scale(1.1); }
    .carousel-nav-wrapper {
        display: flex;
        justify-content: center;
        margin-top: 20px;
    }
    .go-to-shop-btn { 
        font-size: 11px; 
        padding: 20px 32px;
    }
}

@media (max-width: 480px) {
    .carousel-card { flex: 0 0 calc(50% - 8px); }
    .carousel-image-wrapper { height: 140px; }
    .carousel-emoji { font-size: 50px; }
    .carousel-title { font-size: 8px; min-height: 26px; }
    .carousel-add-btn { font-size: 8px; padding: 10px; }
    .featured-title { font-size: 18px; }
}
</style>

