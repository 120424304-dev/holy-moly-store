// 找到产品卡片中的 ADD 按钮，改成这样：
<button class="quick-btn add-cart" onclick="addToCartFromProduct(this, 1, 'Mario Mushroom Keychain', 18, '🍄')">🛒 ADD</button>

// 对应的JS函数：
function addToCartFromProduct(btn, id, name, price, emoji) {
    event.stopPropagation();
    
    // 按钮动画
    const originalText = btn.innerHTML;
    btn.innerHTML = '✓ ADDED!';
    btn.style.background = '#00FF00';
    btn.style.transform = 'scale(1.05)';
    
    // 添加到购物车
    if (typeof window.addToCart === 'function') {
        window.addToCart({
            id: id,
            name: name,
            price: price,
            emoji: emoji,
            variant: 'Color: Default'
        });
    }
    
    // 恢复按钮
    setTimeout(() => {
        btn.innerHTML = originalText;
        btn.style.background = '';
        btn.style.transform = '';
    }, 1500);
}
