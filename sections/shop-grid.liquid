{{ 'shop-grid.css' | asset_url | stylesheet_tag }}

<!-- 导航栏 -->
<nav class="navbar shop-navbar" id="navbar">
    <div class="navbar-container">
        <a href="/" class="navbar-logo">
            <span class="navbar-logo-icon">👾</span>
            <span>HOLY MOLY</span>
        </a>
        <ul class="navbar-menu">
            <li><a href="/pages/shop" class="navbar-link active">🛒 SHOP</a></li>
            <li><a href="/#custom" class="navbar-link">🎨 CUSTOM</a></li>
            <li><a href="/#features" class="navbar-link">✨ FEATURES</a></li>
            <li><a href="/#contact" class="navbar-link">📧 CONTACT</a></li>
        </ul>
        <div class="navbar-cart" onclick="openCart()">
            🛒
            <span class="cart-badge hidden" id="cartBadge">0</span>
        </div>
        <button class="hamburger" id="hamburger" onclick="toggleMobileMenu()">
            <span class="hamburger-line"></span>
            <span class="hamburger-line"></span>
            <span class="hamburger-line"></span>
        </button>
    </div>
</nav>

<!-- 移动端菜单 -->
<div class="mobile-menu" id="mobileMenu">
    <a href="/pages/shop" class="navbar-link active">🛒 SHOP</a>
    <a href="/#custom" class="navbar-link">🎨 CUSTOM</a>
    <a href="/#features" class="navbar-link">✨ FEATURES</a>
    <a href="/#contact" class="navbar-link">📧 CONTACT</a>
    <div class="navbar-cart" onclick="openCart(); toggleMobileMenu();">
        🛒
        <span class="cart-badge hidden" id="cartBadgeMobile">0</span>
    </div>
</div>

<div class="shop-page">
    <div class="shop-header">
        <div class="shop-title">THE LOOT BOX</div>
        <div class="shop-subtitle">← Scroll to explore →</div>
    </div>

    <div class="control-panel">
        <div class="pixel-search">
            <span class="search-icon">🔍</span>
            <input type="text" id="searchInput" placeholder="SEARCH ITEMS..." onkeyup="searchProducts()">
        </div>
        <div class="filter-chips">
            <button class="chip active" onclick="filterProducts('all', this)">ALL</button>
            <button class="chip" onclick="filterProducts('keychain', this)">KEYCHAINS</button>
            <button class="chip" onclick="filterProducts('magnet', this)">MAGNETS</button>
            <button class="chip" onclick="filterProducts('diy', this)">DIY KITS</button>
        </div>
        
        <!-- 像素风格自定义下拉菜单 -->
        <div class="pixel-dropdown" id="sortDropdown">
            <button class="pixel-dropdown-btn" onclick="toggleDropdown()">
                <span class="dropdown-icon">🆕</span>
                <span class="dropdown-text" id="sortText">NEWEST</span>
                <span class="dropdown-arrow">▼</span>
            </button>
            <div class="pixel-dropdown-menu" id="dropdownMenu">
                <div class="dropdown-item active" onclick="selectSort('newest', '🆕', 'NEWEST')">
                    <span class="item-icon">🆕</span>
                    <span class="item-text">NEWEST</span>
                </div>
                <div class="dropdown-item" onclick="selectSort('price-low', '💰', 'PRICE: LOW TO HIGH')">
                    <span class="item-icon">💰</span>
                    <span class="item-text">PRICE: LOW TO HIGH</span>
                </div>
                <div class="dropdown-item" onclick="selectSort('price-high', '💎', 'PRICE: HIGH TO LOW')">
                    <span class="item-icon">💎</span>
                    <span class="item-text">PRICE: HIGH TO LOW</span>
                </div>
                <div class="dropdown-item" onclick="selectSort('popular', '🔥', 'MOST POPULAR')">
                    <span class="item-icon">🔥</span>
                    <span class="item-text">MOST POPULAR</span>
                </div>
            </div>
        </div>
    </div>

    <div class="products-container" id="productsContainer">
        {% for product in collections.all.products limit: 12 %}
            <div class="product-pixel-card" 
                 data-category="{{ product.type | handleize | default: 'keychain' }}" 
                 data-price="{{ product.price | divided_by: 100 }}" 
                 data-name="{{ product.title | downcase }}"
                 onclick="window.location.href='{{ product.url }}'">
                <div class="card-inner">
                    <button class="wishlist-btn" onclick="toggleWishlist(this, event)">♡</button>
                    <div class="quick-actions" onclick="event.stopPropagation()">
                        <button class="quick-btn quick-view" onclick="quickView('{{ product.title }}', event)">👁️ QUICK VIEW</button>
                        <button class="quick-btn add-cart" onclick="addToCart(event)">🛒 ADD TO CART</button>
                    </div>
                    <div class="card-image-wrapper">
                        <div class="card-image" style="background: linear-gradient(145deg, #FFE600, #FFB800);">
                            {% if product.featured_image %}
                                <img src="{{ product.featured_image | image_url: width: 400 }}" alt="{{ product.title }}" class="product-img">
                            {% else %}
                                <div class="pixel-placeholder">🎮</div>
                            {% endif %}
                        </div>
                        {% if product.compare_at_price > product.price %}
                            <span class="card-badge sale">SALE</span>
                        {% elsif product.tags contains 'new' %}
                            <span class="card-badge new">NEW</span>
                        {% endif %}
                    </div>
                    <div class="card-info">
                        <div class="card-meta">
                            <span class="card-type">{{ product.type | upcase | default: 'ITEM' }}</span>
                            <span class="card-stock {% if product.available %}in{% else %}out{% endif %}">
                                {% if product.available %}● IN STOCK{% else %}○ SOLD OUT{% endif %}
                            </span>
                        </div>
                        <h3 class="card-title">{{ product.title }}</h3>
                        <div class="card-footer">
                            <span class="current-price">${{ product.price | money_without_currency }}</span>
                            <span class="card-rating">⭐ 4.8</span>
                        </div>
                    </div>
                </div>
                <div class="pixel-corners">
                    <span class="corner tl"></span><span class="corner tr"></span>
                    <span class="corner bl"></span><span class="corner br"></span>
                </div>
            </div>
        {% endfor %}
    </div>

    <div class="load-more-container">
        <button class="load-more-btn" onclick="this.innerHTML='📦 NO MORE LOOT'; this.disabled=true">📦 LOAD MORE LOOT</button>
    </div>
</div>

<script>
// 移动端菜单
function toggleMobileMenu() {
    var menu = document.getElementById('mobileMenu');
    var hamburger = document.getElementById('hamburger');
    if (menu && hamburger) {
        menu.classList.toggle('active');
        hamburger.classList.toggle('active');
    }
}

// 下拉菜单控制
function toggleDropdown() {
    const dropdown = document.getElementById('sortDropdown');
    dropdown.classList.toggle('open');
    
    if (dropdown.classList.contains('open')) {
        setTimeout(() => {
            document.addEventListener('click', closeDropdownOutside);
        }, 10);
    }
}

function closeDropdownOutside(e) {
    const dropdown = document.getElementById('sortDropdown');
    if (!dropdown.contains(e.target)) {
        dropdown.classList.remove('open');
        document.removeEventListener('click', closeDropdownOutside);
    }
}

function selectSort(value, icon, text) {
    document.getElementById('sortText').textContent = text;
    document.querySelector('.dropdown-icon').textContent = icon;
    
    document.querySelectorAll('.dropdown-item').forEach(item => {
        item.classList.remove('active');
    });
    event.currentTarget.classList.add('active');
    
    document.getElementById('sortDropdown').classList.remove('open');
    document.removeEventListener('click', closeDropdownOutside);
    
    const container = document.getElementById('productsContainer');
    const cards = Array.from(container.children);
    
    cards.sort((a, b) => {
        const priceA = parseFloat(a.dataset.price);
        const priceB = parseFloat(b.dataset.price);
        if (value === 'price-low') return priceA - priceB;
        if (value === 'price-high') return priceB - priceA;
        return 0;
    });
    
    cards.forEach((card, index) => {
        card.style.opacity = '0';
        card.style.transform = 'translateY(20px)';
        setTimeout(() => {
            container.appendChild(card);
            card.style.transition = 'all 0.4s ease';
            card.style.opacity = '1';
            card.style.transform = 'translateY(0)';
        }, index * 50);
    });
    
    createPixelBurst(event.currentTarget);
}

// 像素粒子爆炸
function createPixelBurst(element) {
    const rect = element.getBoundingClientRect();
    const colors = ['#FFE600', '#FF2D7D', '#00D9FF', '#9D4EDD'];
    
    for (let i = 0; i < 6; i++) {
        const particle = document.createElement('div');
        particle.style.cssText = `
            position: fixed;
            width: 8px;
            height: 8px;
            background: ${colors[Math.floor(Math.random() * colors.length)]};
            left: ${rect.left + rect.width / 2}px;
            top: ${rect.top + rect.height / 2}px;
            pointer-events: none;
            z-index: 9999;
        `;
        particle.style.setProperty('--angle', (i * 60) + 'deg');
        particle.style.animation = 'particlePop 0.5s ease forwards';
        document.body.appendChild(particle);
        setTimeout(() => particle.remove(), 500);
    }
}

function filterProducts(category, btn) {
    document.querySelectorAll('.chip').forEach(c => c.classList.remove('active'));
    btn.classList.add('active');
    
    document.querySelectorAll('.product-pixel-card').forEach(card => {
        if (category === 'all' || card.dataset.category === category) {
            card.style.display = 'block';
            card.style.animation = 'popIn 0.4s ease';
        } else {
            card.style.display = 'none';
        }
    });
}

function searchProducts() {
    const term = document.getElementById('searchInput').value.toLowerCase();
    document.querySelectorAll('.product-pixel-card').forEach(card => {
        if (card.dataset.name.includes(term)) {
            card.style.display = 'block';
        } else {
            card.style.display = 'none';
        }
    });
}

function toggleWishlist(btn, e) {
    e.stopPropagation();
    btn.classList.toggle('active');
    btn.innerHTML = btn.classList.contains('active') ? '♥' : '♡';
}

function quickView(title, e) {
    e.stopPropagation();
    alert('Quick view: ' + title);
}

function addToCart(e) {
    e.stopPropagation();
    const btn = e.target;
    btn.innerHTML = '✓ ADDED!';
    btn.style.background = '#00FF00';
    setTimeout(() => {
        btn.innerHTML = '🛒 ADD TO CART';
        btn.style.background = '#00D9FF';
    }, 1500);
}

function openCart() {
    alert('购物车功能需要接入 Shopify API');
}

// 导航栏滚动效果
var navbar = document.getElementById('navbar');
if (navbar) {
    window.addEventListener('scroll', function() {
        if (window.scrollY > 50) {
            navbar.classList.add('scrolled');
        } else {
            navbar.classList.remove('scrolled');
        }
    });
}

// 3D tilt effect
document.querySelectorAll('.product-pixel-card').forEach(card => {
    card.addEventListener('mousemove', (e) => {
        const rect = card.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        const centerX = rect.width / 2;
        const centerY = rect.height / 2;
        const rotateX = (y - centerY) / 20;
        const rotateY = (centerX - x) / 20;
        card.style.transform = `perspective(1000px) rotateX(${-rotateX}deg) rotateY(${-rotateY}deg)`;
    });
    card.addEventListener('mouseleave', () => card.style.transform = '');
});
</script>

<style>
/* 导航栏样式 */
.shop-navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    padding: 16px 40px;
    background: rgba(10, 10, 15, 0.95);
    backdrop-filter: blur(10px);
    border-bottom: 4px solid #FFE600;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
}

.navbar-container {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
}

.navbar-logo {
    font-family: 'Press Start 2P', cursive;
    font-size: 18px;
    color: #FFE600;
    text-decoration: none;
    text-shadow: 3px 3px 0px rgba(0, 0, 0, 0.5);
    display: flex;
    align-items: center;
    gap: 10px;
    transition: all 0.3s;
}

.navbar-logo:hover {
    color: #FF2D7D;
    transform: scale(1.05);
}

.navbar-logo-icon {
    font-size: 24px;
    animation: logoBounce 2s ease-in-out infinite;
}

@keyframes logoBounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-5px); }
}

.navbar-menu {
    display: flex;
    align-items: center;
    gap: 8px;
    list-style: none;
    margin: 0;
    padding: 0;
}

.navbar-link {
    font-family: 'Press Start 2P', cursive;
    font-size: 10px;
    color: rgba(255, 255, 255, 0.8);
    text-decoration: none;
    padding: 12px 16px;
    position: relative;
    transition: all 0.3s;
    display: flex;
    align-items: center;
    gap: 6px;
}

.navbar-link::before {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 0;
    height: 3px;
    background: #FFE600;
    transition: width 0.3s;
    box-shadow: 0 0 10px #FFE600;
}

.navbar-link:hover, .navbar-link.active {
    color: #FFE600;
}

.navbar-link:hover::before, .navbar-link.active::before {
    width: 80%;
}

.navbar-cart {
    position: relative;
    width: 50px;
    height: 50px;
    background: #FFE600;
    border: 4px solid #000;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    cursor: pointer;
    box-shadow: 4px 4px 0px #000;
    transition: all 0.2s;
}

.navbar-cart:hover {
    transform: translate(2px, 2px);
    box-shadow: 2px 2px 0px #000;
    background: #FF2D7D;
}

.cart-badge {
    position: absolute;
    top: -10px;
    right: -10px;
    width: 26px;
    height: 26px;
    background: #FF2D7D;
    border: 3px solid #000;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Press Start 2P', cursive;
    font-size: 10px;
    color: white;
}

.cart-badge.hidden {
    display: none;
}

.hamburger {
    display: none;
    flex-direction: column;
    gap: 6px;
    padding: 10px;
    cursor: pointer;
    background: transparent;
    border: none;
}

.hamburger-line {
    width: 30px;
    height: 4px;
    background: #FFE600;
    border-radius: 2px;
    transition: all 0.3s;
    box-shadow: 2px 2px 0px rgba(0, 0, 0, 0.5);
}

.mobile-menu {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(10, 10, 15, 0.98);
    backdrop-filter: blur(20px);
    z-index: 999;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 30px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s;
}

.mobile-menu.active {
    opacity: 1;
    pointer-events: all;
    display: flex;
}

.mobile-menu .navbar-link {
    font-size: 16px;
    padding: 20px;
}

/* 像素下拉菜单 */
.pixel-dropdown {
    position: relative;
    z-index: 100;
}

.pixel-dropdown-btn {
    font-family: 'Press Start 2P', cursive;
    font-size: 9px;
    padding: 14px 20px;
    background: #FF2D7D;
    border: 4px solid #000;
    border-radius: 8px;
    color: white;
    cursor: pointer;
    box-shadow: 4px 4px 0 #000;
    display: flex;
    align-items: center;
    gap: 10px;
    min-width: 220px;
    transition: all 0.2s;
}

.pixel-dropdown-btn:hover {
    transform: translate(2px, 2px);
    box-shadow: 2px 2px 0 #000;
    background: #ff4d8f;
}

.pixel-dropdown-btn:active {
    transform: translate(4px, 4px);
    box-shadow: 0 0 0 #000;
}

.dropdown-arrow {
    transition: transform 0.3s;
    font-size: 10px;
    margin-left: auto;
}

.pixel-dropdown.open .dropdown-arrow {
    transform: rotate(180deg);
}

.pixel-dropdown-menu {
    position: absolute;
    top: calc(100% + 12px);
    left: 0;
    right: 0;
    background: #1a1a2e;
    border: 4px solid #FFE600;
    border-radius: 12px;
    box-shadow: 6px 6px 0 #000;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-10px) scale(0.95);
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    overflow: hidden;
}

.pixel-dropdown.open .pixel-dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0) scale(1);
}

.dropdown-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 20px;
    font-family: 'Press Start 2P', cursive;
    font-size: 9px;
    color: rgba(255,255,255,0.8);
    cursor: pointer;
    transition: all 0.2s;
    border-bottom: 2px solid rgba(255,230,0,0.1);
}

.dropdown-item:last-child {
    border-bottom: none;
}

.dropdown-item:hover {
    background: #FFE600;
    color: #000;
    padding-left: 28px;
}

.dropdown-item.active {
    background: rgba(255,230,0,0.2);
    color: #FFE600;
}

.dropdown-item.active:hover {
    background: #FFE600;
    color: #000;
}

.item-icon {
    font-size: 14px;
}

.dropdown-item.active::after {
    content: '✓';
    margin-left: auto;
    font-size: 12px;
    color: #00D9FF;
}

.dropdown-item.active:hover::after {
    color: #000;
}

.pixel-dropdown-menu::before {
    content: '';
    position: absolute;
    top: -12px;
    right: 30px;
    width: 0;
    height: 0;
    border-left: 12px solid transparent;
    border-right: 12px solid transparent;
    border-bottom: 12px solid #FFE600;
}

