<script>
const productVariants = [
  {%- for variant in product.variants -%}
  {
    id: {{ variant.id }},
    title: "{{ variant.title | escape }}",
    price: {{ variant.price }},
    compare_at_price: {{ variant.compare_at_price | default: 0 }},
    available: {{ variant.available | json }},
    inventory_quantity: {{ variant.inventory_quantity | default: 0 }},
    options: {
      {%- for option in product.options -%}
      "{{ option }}": "{{ variant.options[forloop.index0] | escape }}"{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    }
  }{%- unless forloop.last %},{% endunless -%}
  {%- endfor -%}
];

let currentQuantity = 1;
let selectedVariant = {{ current_variant.id }};
let selectedOptions = {};

{%- for option in product.options -%}
selectedOptions["{{ option | escape }}"] = "{{ current_variant.options[forloop.index0] | escape }}";
{%- endfor -%}

function findVariant() {
  return productVariants.find(v => {
    return Object.entries(selectedOptions).every(([key, value]) => v.options[key] === value);
  });
}

function selectOption(optionName, value, btn) {
  selectedOptions[optionName] = value;
  
  document.querySelectorAll(`[data-option="${optionName}"]`).forEach(el => {
    el.classList.remove('selected');
  });
  btn.classList.add('selected');
  
  const variant = findVariant();
  if (variant) {
    selectedVariant = variant.id;
    updateProductDisplay(variant);
  }
}

function updateProductDisplay(variant) {
  document.getElementById('productPrice').textContent = formatMoney(variant.price);
  
  const comparePriceEl = document.getElementById('comparePrice');
  if (comparePriceEl) {
    if (variant.compare_at_price > variant.price) {
      comparePriceEl.textContent = formatMoney(variant.compare_at_price);
      comparePriceEl.style.display = 'inline';
    } else {
      comparePriceEl.style.display = 'none';
    }
  }
  
  const stockStatus = document.getElementById('stockStatus');
  const stockText = document.getElementById('stockText');
  const addBtn = document.getElementById('addToCartBtn');
  
  if (variant.available) {
    stockStatus.className = 'stock-status ' + (variant.inventory_quantity < 10 ? 'low' : '');
    stockText.textContent = variant.inventory_quantity < 10 
      ? '⚡ LOW STOCK - Only ' + variant.inventory_quantity + ' left!'
      : '✓ IN STOCK - Ships in 24 hours';
    addBtn.disabled = false;
    addBtn.innerHTML = '<span>🛒 ADD TO CART</span>';
  } else {
    stockStatus.className = 'stock-status out';
    stockText.textContent = '❌ OUT OF STOCK';
    addBtn.disabled = true;
    addBtn.innerHTML = '<span>❌ SOLD OUT</span>';
  }
}

function updateQuantity(change) {
  currentQuantity = Math.max(1, Math.min(10, currentQuantity + change));
  document.getElementById('quantityInput').value = currentQuantity;
}

async function addProductToCart() {
  const btn = document.getElementById('addToCartBtn');
  if (btn.disabled) return;
  
  const originalText = btn.innerHTML;
  btn.innerHTML = '<span>⏳ ADDING...</span>';
  btn.disabled = true;
  
  try {
    const response = await fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: selectedVariant, quantity: currentQuantity })
    });
    
    if (!response.ok) throw new Error('Failed to add');
    
    animateCartIcon();
    openCartDrawer();
    
    const cart = await fetch('/cart.js').then(r => r.json());
    updateAllCartBadges(cart.item_count);
    
  } catch (error) {
    alert('Failed to add to cart. Please try again.');
  } finally {
    btn.innerHTML = originalText;
    btn.disabled = false;
  }
}

function changeImage(src, thumb) {
  const mainImage = document.getElementById('mainImage');
  if (mainImage) {
    mainImage.style.opacity = '0';
    setTimeout(() => {
      mainImage.src = src;
      mainImage.style.opacity = '1';
    }, 200);
  }
  
  document.querySelectorAll('.gallery-thumb').forEach(t => t.classList.remove('active'));
  thumb.classList.add('active');
}

function switchTab(tabId, btn) {
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
  
  btn.classList.add('active');
  document.getElementById('tab-' + tabId).classList.add('active');
}

function toggleWishlist(btn) {
  btn.classList.toggle('active');
  btn.textContent = btn.classList.contains('active') ? '♥' : '♡';
}

function toggleMobileMenu() {
  document.getElementById('mobileMenu').classList.toggle('active');
}

function formatMoney(cents) {
  return '$' + (cents / 100).toFixed(2);
}

function animateCartIcon() {
  const icons = document.querySelectorAll('.navbar-cart');
  icons.forEach(icon => {
    icon.style.animation = 'none';
    icon.offsetHeight;
    icon.style.animation = 'cartShake 0.5s ease';
  });
}

document.addEventListener('DOMContentLoaded', async () => {
  try {
    const cart = await fetch('/cart.js').then(r => r.json());
    if (typeof updateAllCartBadges === 'function') {
      updateAllCartBadges(cart.item_count);
    }
  } catch (e) {
    console.error('Failed to load cart:', e);
  }
});
</script>

