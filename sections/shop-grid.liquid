.wishlist-btn {
    position: absolute;
    top: 16px;
    right: 16px;
    z-index: 10;
    width: 44px;
    height: 44px;
    background: rgba(0,0,0,0.5);
    border: 3px solid rgba(255,255,255,0.3);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    cursor: pointer;
    transition: all 0.3s;
}

.wishlist-btn:hover, .wishlist-btn.active {
    background: #FF2D7D;
    border-color: #000;
    box-shadow: 3px 3px 0 #000;
}

.quick-actions {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    display: flex;
    flex-direction: column;
    gap: 12px;
    opacity: 0;
    z-index: 5;
    transition: opacity 0.3s;
}

.product-pixel-card:hover .quick-actions {
    opacity: 1;
}

.quick-btn {
    font-family: 'Press Start 2P', cursive;
    font-size: 9px;
    padding: 14px 24px;
    border: 3px solid #000;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s;
    white-space: nowrap;
    box-shadow: 4px 4px 0 #000;
}

.quick-btn:hover {
    transform: translate(2px, 2px);
    box-shadow: 2px 2px 0 #000;
}

