<style>
@import url('https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap');

* { box-sizing: border-box; }

.product-page { background: #0a0a0f; min-height: 100vh; padding: 100px 20px 60px; font-family: 'Inter', sans-serif; }

.navbar { position: fixed; top: 0; left: 0; right: 0; z-index: 1000; padding: 16px 40px; background: rgba(10,10,15,0.95); backdrop-filter: blur(10px); border-bottom: 4px solid #FFE600; box-shadow: 0 10px 40px rgba(0,0,0,0.5); }
.navbar-container { max-width: 1400px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; }
.navbar-logo { font-family: 'Press Start 2P'; font-size: 18px; color: #FFE600; text-decoration: none; display: flex; align-items: center; gap: 10px; }
.navbar-logo-icon { font-size: 24px; animation: logoBounce 2s ease-in-out infinite; }
@keyframes logoBounce { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-5px); } }
.navbar-menu { display: flex; gap: 8px; list-style: none; margin: 0; padding: 0; }
.navbar-link { font-family: 'Press Start 2P'; font-size: 10px; color: rgba(255,255,255,0.8); text-decoration: none; padding: 12px 16px; position: relative; transition: all 0.3s; }
.navbar-link:hover, .navbar-link.active { color: #FFE600; }
.navbar-cart { position: relative; width: 50px; height: 50px; background: #FFE600; border: 4px solid #000; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 20px; cursor: pointer; box-shadow: 4px 4px 0 #000; }
.navbar-cart:hover { transform: translate(2px,2px); box-shadow: 2px 2px 0 #000; background: #FF2D7D; }
.hamburger { display: none; flex-direction: column; gap: 6px; padding: 10px; cursor: pointer; background: transparent; border: none; }
.hamburger-line { width: 30px; height: 4px; background: #FFE600; border-radius: 2px; box-shadow: 2px 2px 0 rgba(0,0,0,0.5); }

.mobile-menu { display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(10,10,15,0.98); z-index: 999; flex-direction: column; align-items: center; justify-content: center; gap: 30px; opacity: 0; pointer-events: none; }
.mobile-menu.active { opacity: 1; pointer-events: all; display: flex; }

.breadcrumb { max-width: 1400px; margin: 0 auto 30px; padding: 0 20px; display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
.breadcrumb-link { font-family: 'Press Start 2P'; font-size: 9px; color: rgba(255,255,255,0.5); text-decoration: none; transition: color 0.3s; }
.breadcrumb-link:hover { color: #FFE600; }
.breadcrumb-separator { color: rgba(255,255,255,0.3); font-size: 10px; }
.breadcrumb-current { font-family: 'Press Start 2P'; font-size: 9px; color: #FFE600; }

.product-container { max-width: 1400px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: start; }
@media (max-width: 1024px) { .product-container { grid-template-columns: 1fr; gap: 40px; } }

.product-images { position: sticky; top: 100px; }
@media (max-width: 1024px) { .product-images { position: relative; top: 0; } }

.main-image-container { position: relative; background: linear-gradient(145deg, #1a1a2e, #252542); border: 5px solid #FFE600; border-radius: 24px; overflow: hidden; box-shadow: 0 20px 60px rgba(0,0,0,0.5); aspect-ratio: 1; display: flex; align-items: center; justify-content: center; }
.main-image { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s; }
.main-image:hover { transform: scale(1.05); }
.product-emoji-display { font-size: 200px; animation: float 3s ease-in-out infinite; filter: drop-shadow(0 20px 40px rgba(0,0,0,0.5)); }
@keyframes float { 0%,100% { transform: translateY(0) rotate(0deg); } 50% { transform: translateY(-20px) rotate(5deg); } }

.image-gallery { display: flex; gap: 16px; margin-top: 24px; justify-content: center; flex-wrap: wrap; }
.gallery-thumb { width: 80px; height: 80px; border: 4px solid transparent; border-radius: 12px; cursor: pointer; overflow: hidden; transition: all 0.3s; background: rgba(255,255,255,0.05); display: flex; align-items: center; justify-content: center; }
.gallery-thumb.active, .gallery-thumb:hover { border-color: #FFE600; box-shadow: 4px 4px 0 #000; transform: translate(-2px,-2px); }
.gallery-thumb img { width: 100%; height: 100%; object-fit: cover; }
.gallery-thumb .thumb-emoji { font-size: 36px; }

.product-badge { position: absolute; top: 20px; left: 20px; font-family: 'Press Start 2P'; font-size: 10px; padding: 12px 20px; background: #FF2D7D; border: 4px solid #000; border-radius: 8px; color: white; box-shadow: 4px 4px 0 #000; animation: badgePulse 2s infinite; z-index: 10; }
@keyframes badgePulse { 0%,100% { transform: scale(1); } 50% { transform: scale(1.05); } }
.product-badge.sale { background: #FF2D7D; }
.product-badge.new { background: #00D9FF; color: #000; }

.product-info { background: rgba(255,255,255,0.03); border: 4px solid rgba(255,230,0,0.2); border-radius: 24px; padding: 40px; }
@media (max-width: 768px) { .product-info { padding: 24px; } }

.product-type { font-family: 'Press Start 2P'; font-size: 10px; color: #9D4EDD; margin-bottom: 16px; display: inline-block; padding: 8px 16px; background: rgba(157,78,221,0.1); border-radius: 8px; }
.product-title { font-family: 'Press Start 2P'; font-size: clamp(20px, 4vw, 28px); color: #FFE600; line-height: 1.5; margin-bottom: 20px; }

.product-rating { display: flex; align-items: center; gap: 12px; margin-bottom: 24px; flex-wrap: wrap; }
.stars { font-size: 18px; color: #FFB800; letter-spacing: 2px; }
.rating-text { font-family: 'Press Start 2P'; font-size: 10px; color: rgba(255,255,255,0.6); }
.rating-count { font-size: 12px; color: rgba(255,255,255,0.4); }

.product-price-section { display: flex; align-items: baseline; gap: 16px; margin-bottom: 32px; flex-wrap: wrap; }
.current-price { font-family: 'Press Start 2P'; font-size: clamp(24px, 5vw, 36px); color: #FF2D7D; }
.compare-price { font-family: 'Press Start 2P'; font-size: 20px; color: rgba(255,255,255,0.4); text-decoration: line-through; }
.discount-badge { font-family: 'Press Start 2P'; font-size: 10px; padding: 8px 16px; background: #00D9FF; border: 3px solid #000; border-radius: 8px; color: #000; }

.product-description { color: rgba(255,255,255,0.7); font-size: 15px; line-height: 1.8; margin-bottom: 32px; padding-bottom: 32px; border-bottom: 2px solid rgba(255,255,255,0.1); }

.product-options { margin-bottom: 32px; }
.option-group { margin-bottom: 24px; }
.option-label { font-family: 'Press Start 2P'; font-size: 10px; color: #FFE600; margin-bottom: 12px; display: block; }
.color-options { display: flex; gap: 12px; flex-wrap: wrap; }
.color-option { width: 48px; height: 48px; border: 4px solid transparent; border-radius: 12px; cursor: pointer; position: relative; transition: all 0.3s; box-shadow: 3px 3px 0 #000; }
.color-option:hover { transform: translate(-2px,-2px); box-shadow: 5px 5px 0 #000; }
.color-option.selected { border-color: #FFE600; box-shadow: 0 0 0 4px rgba(255,230,0,0.3), 3px 3px 0 #000; }
.color-option::after { content: '✓'; position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; font-size: 20px; color: white; text-shadow: 2px 2px 0 #000; opacity: 0; transition: opacity 0.3s; }
.color-option.selected::after { opacity: 1; }

.size-options { display: flex; gap: 12px; flex-wrap: wrap; }
.size-option { font-family: 'Press Start 2P'; font-size: 10px; padding: 16px 24px; background: rgba(255,255,255,0.05); border: 3px solid rgba(255,255,255,0.2); border-radius: 12px; color: rgba(255,255,255,0.8); cursor: pointer; transition: all 0.3s; min-width: 60px; text-align: center; }
.size-option:hover { border-color: #FFE600; color: #FFE600; }
.size-option.selected { background: #FFE600; border-color: #000; color: #000; box-shadow: 4px 4px 0 #000; transform: translate(-2px,-2px); }
.size-option:disabled { opacity: 0.3; cursor: not-allowed; }

.quantity-section { margin-bottom: 32px; }
.quantity-control { display: inline-flex; align-items: center; border: 4px solid #000; border-radius: 12px; overflow: hidden; box-shadow: 4px 4px 0 #000; }
.quantity-btn { width: 50px; height: 56px; background: #FFE600; border: none; font-family: 'Press Start 2P'; font-size: 16px; cursor: pointer; transition: all 0.2s; }
.quantity-btn:hover { background: #FF2D7D; color: white; }
.quantity-input { width: 70px; height: 56px; background: white; border: none; font-family: 'Press Start 2P'; font-size: 14px; text-align: center; }

.stock-status { display: flex; align-items: center; gap: 8px; margin-bottom: 32px; padding: 16px 20px; background: rgba(0,217,255,0.1); border: 2px solid #00D9FF; border-radius: 12px; }
.stock-status.low { background: rgba(255,184,0,0.1); border-color: #FFB800; }
.stock-status.out { background: rgba(255,45,125,0.1); border-color: #FF2D7D; }
.stock-dot { width: 12px; height: 12px; background: #00D9FF; border-radius: 50%; animation: pulse 2s infinite; }
@keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.5; } }
.stock-text { font-family: 'Press Start 2P'; font-size: 10px; color: #00D9FF; }

.action-buttons { display: flex; gap: 16px; margin-bottom: 32px; flex-wrap: wrap; }
.add-to-cart-btn { flex: 1; min-width: 200px; padding: 24px 32px; background: #00D9FF; border: 5px solid #000; border-radius: 16px; font-family: 'Press Start 2P'; font-size: 14px; color: #000; cursor: pointer; box-shadow: 8px 8px 0 #000; transition: all 0.3s; display: flex; align-items: center; justify-content: center; gap: 12px; }
.add-to-cart-btn:hover:not(:disabled) { transform: translate(4px,4px); box-shadow: 4px 4px 0 #000; background: #FFE600; }
.add-to-cart-btn:disabled { background: #666; cursor: not-allowed; opacity: 0.5; }
.wishlist-btn-large { width: 70px; height: 70px; background: rgba(255,45,125,0.1); border: 4px solid rgba(255,45,125,0.3); border-radius: 16px; font-size: 28px; cursor: pointer; transition: all 0.3s; display: flex; align-items: center; justify-content: center; }
.wishlist-btn-large:hover, .wishlist-btn-large.active { background: #FF2D7D; border-color: #000; box-shadow: 4px 4px 0 #000; transform: scale(1.05); }

.shipping-info { padding: 20px; background: rgba(255,230,0,0.05); border: 2px dashed rgba(255,230,0,0.3); border-radius: 12px; margin-bottom: 32px; }
.shipping-text { font-family: 'Press Start 2P'; font-size: 9px; color: rgba(255,255,255,0.6); text-align: center; line-height: 1.8; }
.shipping-highlight { color: #FFE600; }

.product-features { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
.feature-item { display: flex; flex-direction: column; align-items: center; gap: 8px; padding: 20px; background: rgba(255,255,255,0.03); border-radius: 12px; text-align: center; }
.feature-icon { font-size: 28px; }
.feature-text { font-family: 'Press Start 2P'; font-size: 8px; color: rgba(255,255,255,0.6); line-height: 1.6; }
@media (max-width: 768px) { .product-features { grid-template-columns: 1fr; } }

.product-details-tabs { max-width: 1400px; margin: 60px auto 0; padding: 0 20px; }
.tabs-header { display: flex; gap: 8px; margin-bottom: 32px; border-bottom: 4px solid rgba(255,255,255,0.1); flex-wrap: wrap; }
.tab-btn { font-family: 'Press Start 2P'; font-size: 10px; padding: 20px 32px; background: transparent; border: none; color: rgba(255,255,255,0.5); cursor: pointer; position: relative; transition: all 0.3s; }
.tab-btn:hover { color: rgba(255,255,255,0.8); }
.tab-btn.active { color: #FFE600; }
.tab-btn.active::after { content: ''; position: absolute; bottom: -4px; left: 0; right: 0; height: 4px; background: #FFE600; }

.tab-content { display: none; animation: fadeIn 0.4s; }
.tab-content.active { display: block; }
@keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

.tab-panel { background: rgba(255,255,255,0.03); border: 4px solid rgba(255,255,255,0.1); border-radius: 24px; padding: 40px; }
@media (max-width: 768px) { .tab-panel { padding: 24px; } }

.specs-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; }
@media (max-width: 768px) { .specs-grid { grid-template-columns: 1fr; } }
.spec-item { display: flex; justify-content: space-between; padding: 20px; background: rgba(255,255,255,0.03); border-radius: 12px; }
.spec-label { font-family: 'Press Start 2P'; font-size: 9px; color: rgba(255,255,255,0.5); }
.spec-value { font-family: 'Press Start 2P'; font-size: 10px; color: #FFE600; }

.shipping-table { width: 100%; border-collapse: collapse; }
.shipping-table th, .shipping-table td { padding: 20px; text-align: left; border-bottom: 2px solid rgba(255,255,255,0.1); }
.shipping-table th { font-family: 'Press Start 2P'; font-size: 10px; color: #FFE600; }
.shipping-table td { font-size: 14px; color: rgba(255,255,255,0.7); }
.shipping-price { font-family: 'Press Start 2P'; font-size: 12px; color: #00D9FF; }

.review-item { padding: 32px; background: rgba(255,255,255,0.03); border-radius: 16px; margin-bottom: 24px; }
.review-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; flex-wrap: wrap; gap: 12px; }
.reviewer-info { display: flex; align-items: center; gap: 16px; }
.reviewer-avatar { width: 56px; height: 56px; background: linear-gradient(135deg, #FFE600, #FF2D7D); border: 4px solid #000; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 24px; }
.reviewer-name { font-family: 'Press Start 2P'; font-size: 12px; color: white; }
.review-date { font-size: 12px; color: rgba(255,255,255,0.4); }
.review-stars { font-size: 16px; color: #FFB800; }
.review-text { color: rgba(255,255,255,0.7); font-size: 14px; line-height: 1.8; }

.related-products { max-width: 1400px; margin: 80px auto; padding: 0 20px; }
.section-title { font-family: 'Press Start 2P'; font-size: 24px; color: #FFE600; text-align: center; margin-bottom: 40px; }
</style>

<nav class="navbar">
  <div class="navbar-container">
    <a href="/" class="navbar-logo"><span class="navbar-logo-icon">👾</span><span>HOLY MOLY</span></a>
    <ul class="navbar-menu">
      <li><a href="/" class="navbar-link">🏠 HOME</a></li>
      <li><a href="/pages/shop" class="navbar-link">🛒 SHOP</a></li>
      <li><a href="/#custom" class="navbar-link">🎨 CUSTOM</a></li>
      <li><a href="/#features" class="navbar-link">✨ FEATURES</a></li>
    </ul>
    <div class="navbar-cart" onclick="openCart()">🛒<span class="cart-badge hidden" id="cartBadge">0</span></div>
    <button class="hamburger" onclick="toggleMobileMenu()"><span class="hamburger-line"></span><span class="hamburger-line"></span><span class="hamburger-line"></span></button>
  </div>
</nav>

<div class="mobile-menu" id="mobileMenu">
  <a href="/" class="navbar-link">🏠 HOME</a>
  <a href="/pages/shop" class="navbar-link">🛒 SHOP</a>
  <a href="/#custom" class="navbar-link">🎨 CUSTOM</a>
  <a href="/#features" class="navbar-link">✨ FEATURES</a>
  <div class="navbar-cart" onclick="openCart(); toggleMobileMenu();">🛒<span class="cart-badge hidden" id="cartBadgeMobile">0</span></div>
</div>

{%- assign current_variant = product.selected_or_first_available_variant -%}
{%- assign product_emoji = '🎮' -%}
{%- case product.type | downcase -%}
  {%- when 'keychain' -%}{%- assign product_emoji = '🔑' -%}
  {%- when 'magnet' -%}{%- assign product_emoji = '🧲' -%}
  {%- when 'diy kit', 'diy' -%}{%- assign product_emoji = '🎨' -%}
{%- endcase -%}

<div class="product-page">
  <div class="breadcrumb">
    <a href="/" class="breadcrumb-link">🏠 HOME</a>
    <span class="breadcrumb-separator">/</span>
    <a href="/pages/shop" class="breadcrumb-link">🛒 SHOP</a>
    <span class="breadcrumb-separator">/</span>
    <span class="breadcrumb-current">{{ product.title | upcase }}</span>
  </div>

  <div class="product-container">
    <div class="product-images">
      <div class="main-image-container">
        {%- if product.compare_at_price > product.price -%}
          {%- assign discount = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
          <span class="product-badge sale">🔥 -{{ discount }}% OFF</span>
        {%- elsif product.tags contains 'new' -%}
          <span class="product-badge new">✨ NEW</span>
        {%- endif -%}
        
        {%- if product.featured_image -%}
          <img src="{{ product.featured_image | img_url: '800x800' }}" alt="{{ product.title | escape }}" class="main-image" id="mainImage">
        {%- else -%}
          <div class="product-emoji-display" id="mainEmoji">{{ product_emoji }}</div>
        {%- endif -%}
      </div>
      
      {%- if product.images.size > 1 -%}
      <div class="image-gallery">
        {%- for image in product.images limit: 4 -%}
          <div class="gallery-thumb {% if forloop.first %}active{% endif %}" onclick="changeImage('{{ image | img_url: '800x800' }}', this)">
            <img src="{{ image | img_url: '150x150', crop: 'center' }}" alt="{{ product.title | escape }}">
          </div>
        {%- endfor -%}
      </div>
      {%- endif -%}
    </div>

    <div class="product-info">
      <span class="product-type">{{ product.type | default: 'KEYCHAIN' | upcase }}</span>
      <h1 class="product-title">{{ product.title }}</h1>
      
      <div class="product-rating">
        <span class="stars">⭐⭐⭐⭐⭐</span>
        <span class="rating-text">4.9</span>
        <span class="rating-count">({{ product.metafields.reviews.count | default: '128' }} reviews)</span>
      </div>
      
      <div class="product-price-section">
        <span class="current-price" id="productPrice">{{ current_variant.price | money }}</span>
        {%- if current_variant.compare_at_price > current_variant.price -%}
          <span class="compare-price" id="comparePrice">{{ current_variant.compare_at_price | money }}</span>
        {%- endif -%}
      </div>
      
      <div class="product-description">
        {{ product.description | default: 'Handcrafted pixel art made with 1000+ beads. Each piece is unique and made with love! Perfect for gamers, collectors, and anyone who loves retro pixel art.' }}
      </div>
      
      {%- if product.variants.size > 1 -%}
      <div class="product-options" id="variantSelectors">
        {%- for option in product.options_with_values -%}
          <div class="option-group">
            <span class="option-label">{{ option.name | upcase }}</span>
            <div class="{{ option.name | downcase }}-options">
              {%- for value in option.values -%}
                <button type="button" 
                        class="{{ option.name | downcase }}-option {% if option.selected_value == value %}selected{% endif %}"
                        data-option="{{ option.name }}"
                        data-value="{{ value | escape }}"
                        onclick="selectOption('{{ option.name | escape }}', '{{ value | escape }}', this)">
                  {{ value }}
                </button>
              {%- endfor -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
      {%- endif -%}
      
      <div class="quantity-section">
        <span class="option-label">QUANTITY</span>
        <div class="quantity-control">
          <button class="quantity-btn" onclick="updateQuantity(-1)">−</button>
          <input type="text" class="quantity-input" value="1" id="quantityInput" readonly>
          <button class="quantity-btn" onclick="updateQuantity(1)">+</button>
        </div>
      </div>
      
      <div class="stock-status {% if current_variant.inventory_quantity < 10 %}low{% endif %}" id="stockStatus">
        <span class="stock-dot"></span>
        <span class="stock-text" id="stockText">
          {%- if current_variant.available -%}
            {%- if current_variant.inventory_quantity > 10 -%}
              ✓ IN STOCK - Ships in 24 hours
            {%- else -%}
              ⚡ LOW STOCK - Only {{ current_variant.inventory_quantity }} left!
            {%- endif -%}
          {%- else -%}
            ❌ OUT OF STOCK
          {%- endif -%}
        </span>
      </div>
      
      <div class="action-buttons">
        <button class="add-to-cart-btn" id="addToCartBtn" onclick="addProductToCart()" {% unless current_variant.available %}disabled{% endunless %}>
          <span>{% if current_variant.available %}🛒 ADD TO CART{% else %}❌ SOLD OUT{% endif %}</span>
        </button>
        <button class="wishlist-btn-large" onclick="toggleWishlist(this)">♡</button>
      </div>
      
      <div class="shipping-info">
        <p class="shipping-text">
          🚚 <span class="shipping-highlight">FREE SHIPPING</span> on orders over $72<br>
          🎁 Every order includes <span class="shipping-highlight">FREE STICKERS</span> & candy!
        </p>
      </div>
      
      <div class="product-features">
        <div class="feature-item"><span class="feature-icon">✋</span><span class="feature-text">HANDCRAFTED<br>WITH LOVE</span></div>
        <div class="feature-item"><span class="feature-icon">🎨</span><span class="feature-text">1000+ BEADS<br>PER PIECE</span></div>
        <div class="feature-item"><span class="feature-icon">🎁</span><span class="feature-text">GIFT READY<br>PACKAGING</span></div>
      </div>
    </div>
  </div>

  <div class="product-details-tabs">
    <div class="tabs-header">
      <button class="tab-btn active" onclick="switchTab('specs', this)">📋 SPECS</button>
      <button class="tab-btn" onclick="switchTab('shipping', this)">🚚 SHIPPING</button>
      <button class="tab-btn" onclick="switchTab('reviews', this)">⭐ REVIEWS</button>
    </div>
    
    <div class="tab-content active" id="tab-specs">
      <div class="tab-panel">
        <div class="specs-grid">
          <div class="spec-item"><span class="spec-label">MATERIAL</span><span class="spec-value">PERLER BEADS</span></div>
          <div class="spec-item"><span class="spec-label">SIZE</span><span class="spec-value">~3-4 INCHES</span></div>
          <div class="spec-item"><span class="spec-label">WEIGHT</span><span class="spec-value">~30G</span></div>
          <div class="spec-item"><span class="spec-label">HANDMADE IN</span><span class="spec-value">USA 🇺🇸</span></div>
        </div>
      </div>
    </div>
    
    <div class="tab-content" id="tab-shipping">
      <div class="tab-panel">
        <table class="shipping-table">
          <tr><th>📍 REGION</th><th>⏱️ DELIVERY</th><th>💰 PRICE</th></tr>
          <tr><td>USA</td><td>3-5 business days</td><td class="shipping-price">$4.99</td></tr>
          <tr><td>Canada</td><td>5-10 business days</td><td class="shipping-price">$9.99</td></tr>
          <tr><td>International</td><td>7-14 business days</td><td class="shipping-price">$14.99</td></tr>
        </table>
