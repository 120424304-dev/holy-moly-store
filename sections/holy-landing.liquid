            </div>

            <div class="cta-container">
                <!-- 🔥 修改了这一行：href="#products" → href="/pages/shop" -->
                <a href="/pages/shop" class="pixel-btn" onclick="explodeBeads(event)">
                    <span>🎮</span> EXPLORE SHOP
