                </ul>
            </div>
            <div class="footer-column">
                <h4>SUPPORT</h4>
                <ul class="footer-links">
                    <li><a href="#">Shipping</a></li>
                    <li><a href="#">FAQ</a></li>
                    <li><a href="#">Returns</a></li>
                    <li><a href="#">Contact</a></li>
                </ul>
            </div>
            <div class="footer-column">
                <h4>COMPANY</h4>
                <ul class="footer-links">
                    <li><a href="#">About</a></li>
                    <li><a href="#">Blog</a></li>
                    <li><a href="#">Careers</a></li>
                    <li><a href="#">Press</a></li>
                </ul>
            </div>
        </div>
        <div class="footer-bottom">
            <p class="footer-copy">© 2024 HOLY MOLY BEADS — INSERT COIN TO CONTINUE...</p>
        </div>
    </footer>
</div>

<script>
// Loading Animation
var pixelGrid = document.getElementById('pixelGrid');
var activePixels = [0,1,2,3, 8,9,10,11, 16,17,18,19, 24,25,26,27, 33,34, 41,42, 49,50, 56,57,58,59];

if (pixelGrid) {
    for (var i = 0; i < 64; i++) {
        var pixel = document.createElement('div');
        pixel.className = 'pixel-dot';
        if (activePixels.indexOf(i) !== -1) {
            pixel.classList.add('active');
        }
        pixel.style.animationDelay = (Math.random() * 1.5) + 's';
        pixelGrid.appendChild(pixel);
    }
}

setTimeout(function() {
    var loader = document.getElementById('loader');
    var intro = document.getElementById('intro');
    var mainSite = document.getElementById('main-site');

    if (loader) loader.classList.add('hidden');

    setTimeout(function() {
        if (intro) intro.classList.add('active');

        setTimeout(function() {
            if (intro) intro.classList.remove('active');
            if (mainSite) mainSite.classList.add('active');
        }, 800);
    }, 500);
}, 2500);

// Mobile Menu
function toggleMobileMenu() {
    var menu = document.getElementById('mobileMenu');
    var hamburger = document.getElementById('hamburger');
    if (menu && hamburger) {
        menu.classList.toggle('active');
        hamburger.classList.toggle('active');
    }
}

// Custom Cursor
var cursor = document.getElementById('cursor');
var cursorDot = document.getElementById('cursorDot');

if (cursor && cursorDot) {
    document.addEventListener('mousemove', function(e) {
        cursor.style.left = (e.clientX - 20) + 'px';
        cursor.style.top = (e.clientY - 20) + 'px';
        cursorDot.style.left = (e.clientX - 4) + 'px';
        cursorDot.style.top = (e.clientY - 4) + 'px';
    });

    var hoverElements = document.querySelectorAll('a, button, .product-card, .feature-card, .social-icon');
    hoverElements.forEach(function(el) {
        el.addEventListener('mouseenter', function() {
            cursor.classList.add('hover');
        });
        el.addEventListener('mouseleave', function() {
            cursor.classList.remove('hover');
        });
    });
}

// Click Ripple
document.addEventListener('click', function(e) {
    var ripple = document.createElement('div');
    ripple.className = 'click-ripple';
    ripple.style.left = (e.clientX - 10) + 'px';
    ripple.style.top = (e.clientY - 10) + 'px';
    document.body.appendChild(ripple);
    setTimeout(function() {
        ripple.remove();
    }, 600);
});

// Mascot Tilt
var mascot = document.getElementById('mascot');
var mascotContainer = document.getElementById('mascotContainer');

if (mascot && mascotContainer) {
    mascotContainer.addEventListener('mousemove', function(e) {
        var rect = mascotContainer.getBoundingClientRect();
        var x = e.clientX - rect.left;
        var y = e.clientY - rect.top;
        var centerX = rect.width / 2;
        var centerY = rect.height / 2;
        var rotateX = (y - centerY) / 10;
        var rotateY = (centerX - x) / 10;
        mascot.style.transform = 'rotateX(' + rotateX + 'deg) rotateY(' + rotateY + 'deg)';
    });

    mascotContainer.addEventListener('mouseleave', function() {
        mascot.style.transform = '';
    });
}

// Interactions
function explodeBeads(e) {
    for (var i = 0; i < 8; i++) {
        setTimeout(function() {
            var x = e.clientX + (Math.random() - 0.5) * 100;
            var y = e.clientY + (Math.random() - 0.5) * 100;
            var ripple = document.createElement('div');
            ripple.className = 'click-ripple';
            ripple.style.left = (x - 10) + 'px';
            ripple.style.top = (y - 10) + 'px';
            document.body.appendChild(ripple);
            setTimeout(function() {
                ripple.remove();
            }, 600);
        }, i * 50);
    }
}

function cardClick(card) {
    card.style.transform = 'scale(0.95)';
    setTimeout(function() {
        card.style.transform = '';
    }, 200);
}

function productClick(card) {
    card.style.transform = 'scale(0.98) rotate(-2deg)';
    setTimeout(function() {
        card.style.transform = '';
    }, 200);
}

var cartCount = 0;
function addToCart(btn) {
    btn.style.transform = 'scale(1.2)';
    btn.innerHTML = '✓';
    btn.style.background = '#00D9FF';

    cartCount++;
    var badge = document.getElementById('cartBadge');
    var badgeMobile = document.getElementById('cartBadgeMobile');
    if (badge) {
        badge.textContent = cartCount;
        badge.classList.remove('hidden');
    }
    if (badgeMobile) {
        badgeMobile.textContent = cartCount;
        badgeMobile.classList.remove('hidden');
    }

    setTimeout(function() {
        btn.style.transform = '';
        btn.innerHTML = '🛒';
        btn.style.background = '';
    }, 1000);
}

function socialClick(icon) {
    icon.style.transform = 'rotate(360deg) scale(1.2)';
    setTimeout(function() {
        icon.style.transform = '';
    }, 500);
}

function scrollToSection(id) {
    var element = document.getElementById(id);
    if (element) {
        element.scrollIntoView({ behavior: 'smooth' });
    }
}

function smoothScroll(e, id) {
    e.preventDefault();
    scrollToSection(id);
}

function scrollToTop(e) {
    e.preventDefault();
    window.scrollTo({ top: 0, behavior: 'smooth' });
}

function openCart() {
    alert('购物车功能需要接入 Shopify API');
}

// Scroll Animations
var observerOptions = {
    threshold: 0.1,
    rootMargin: '0px 0px -50px 0px'
};

var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
        if (entry.isIntersecting) {
            entry.target.style.opacity = '1';
            entry.target.style.transform = 'translateY(0)';
        }
    });
}, observerOptions);

document.querySelectorAll('.feature-card, .product-card').forEach(function(el) {
    el.style.opacity = '0';
    el.style.transform = 'translateY(30px)';
    el.style.transition = 'opacity 0.6s, transform 0.6s';
    observer.observe(el);
});

// Navbar Scroll Effect
var navbar = document.getElementById('navbar');
if (navbar) {
    window.addEventListener('scroll', function() {
        if (window.scrollY > 50) {
            navbar.classList.add('scrolled');
        } else {
            navbar.classList.remove('scrolled');
        }
    });
}

// Active Link Highlighting
var sections = ['products', 'features', 'custom', 'contact'];
var navLinks = document.querySelectorAll('.navbar-link');

window.addEventListener('scroll', function() {
    var current = '';
    var navbarHeight = navbar ? navbar.offsetHeight : 0;

    sections.forEach(function(sectionId) {
        var section = document.getElementById(sectionId);
        if (section) {
            var sectionTop = section.offsetTop - navbarHeight - 100;
            if (window.scrollY >= sectionTop) {
                current = sectionId;
            }
        }
    });

    navLinks.forEach(function(link) {
        link.classList.remove('active');
        if (link.getAttribute('href') === '#' + current) {
            link.classList.add('active');
        }
    });
});

// Hide cursor on touch devices
if ('ontouchstart' in window) {
    if (cursor) cursor.style.display = 'none';
    if (cursorDot) cursorDot.style.display = 'none';
}
</script>
