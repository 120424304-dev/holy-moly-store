                </div>
                <div class="product-info">
                    <h3 class="product-name">Retro Controller Magnet</h3>
                    <div class="product-footer">
                        <span class="product-price">$28.00</span>
                        <button class="add-btn" onclick="event.stopPropagation(); addToCart(this)">🛒</button>
                    </div>
                </div>
            </div>
            <div class="product-card" onclick="productClick(this)">
                <div class="product-image" style="background: linear-gradient(135deg, #FFD93D, #FFA502);">
                    ⭐
                    <span class="product-tag" style="background: #FFE600; color: #000;">SALE</span>
                </div>
                <div class="product-info">
                    <h3 class="product-name">Star Power Keychain</h3>
                    <div class="product-footer">
                        <span class="product-price">$15.00</span>
                        <button class="add-btn" onclick="event.stopPropagation(); addToCart(this)">🛒</button>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="cta-section" id="custom">
        <div class="cta-particles">
            <div class="cparticle"></div>
            <div class="cparticle"></div>
            <div class="cparticle"></div>
            <div class="cparticle"></div>
        </div>
        <h2 class="cta-title">READY TO CREATE?</h2>
        <p class="cta-desc">Transform your favorite characters into tangible bead masterpieces today!</p>
