            </div>
            <div class="feature-card" onclick="cardClick(this)">
                <div class="feature-icon">⚡</div>
                <h3 class="feature-title">FAST SHIPPING</h3>
                <p class="feature-desc">Worldwide delivery in 10-15 days with tracking</p>
            </div>
            <div class="feature-card" onclick="cardClick(this)">
                <div class="feature-icon">💎</div>
                <h3 class="feature-title">PREMIUM QUALITY</h3>
                <p class="feature-desc">Professional-grade beads with protective coating</p>
            </div>
            <div class="feature-card" onclick="cardClick(this)">
