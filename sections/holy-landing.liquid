                <div class="social-icons">
                    <div class="social-icon" onclick="socialClick(this)">📸</div>
                    <div class="social-icon" onclick="socialClick(this)">🐦</div>
                    <div class="social-icon" onclick="socialClick(this)">📺</div>
                    <div class="social-icon" onclick="socialClick(this)">💬</div>
                </div>
            </div>
            <div class="footer-column">
                <h4>SHOP</h4>
